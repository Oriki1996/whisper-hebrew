# Copy this file to .env and fill in your values
# cp .env.example .env

# Anthropic API key (for Claude Hebrew correction + AI Insights)
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace token (for speaker diarization with pyannote)
# 1. Accept model at: https://huggingface.co/pyannote/speaker-diarization-3.1
# 2. Generate token at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_...

# Whisper model (tiny / small / medium / large)
WHISPER_MODEL=small

# Output directory (default: ./output)
# OUTPUT_DIR=./output
